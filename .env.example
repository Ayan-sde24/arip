# Application
APP_NAME="AI Resume Intelligence Platform"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=true
API_V1_PREFIX="/api/v1"

# Database
DATABASE_HOST="postgres"
DATABASE_PORT=5432
DATABASE_NAME="arip"
DATABASE_USER="arip"
DATABASE_PASSWORD="arip_password"
DATABASE_URL="postgresql+psycopg://arip:arip_password@postgres:5432/arip"

# JWT
JWT_SECRET_KEY="replace-with-a-secure-random-secret"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL="INFO"
LOG_FILE_PATH="logs/arip.log"
LOG_ROTATION="10 MB"
LOG_RETENTION="30 days"

# Storage
STORAGE_ROOT="storage"
UPLOADS_ROOT="storage/uploads"
GENERATED_ROOT="storage/generated"
RESUME_UPLOAD_DIR="storage/uploads/resumes"
JOB_UPLOAD_DIR="storage/uploads/jobs"
REPORT_OUTPUT_DIR="storage/generated/reports"
GENERATED_RESUME_DIR="storage/generated/resumes"
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_UPLOAD_EXTENSIONS='["pdf","docx"]'
ALLOWED_UPLOAD_MIME_TYPES='["application/pdf","application/vnd.openxmlformats-officedocument.wordprocessingml.document"]'

# Embeddings
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"

# LLM Providers
OPENAI_API_KEY="replace-with-openai-api-key"
